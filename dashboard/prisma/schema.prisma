generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Store {
  id                  String   @id @default(uuid())
  status              String   @default("PENDING")
  dropName            String   @map("drop_name")
  endDate             DateTime @map("end_date") @db.Timestamptz()
  postDropAction      String   @map("post_drop_action")
  locusProjectId      String?  @map("locus_project_id")
  locusServiceId      String?  @map("locus_service_id")
  locusServiceUrl     String?  @map("locus_service_url")
  locusDeploymentId   String?  @map("locus_deployment_id")
  slug                String?  @unique
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz()
  activatedAt         DateTime? @map("activated_at") @db.Timestamptz()
  soldOutAt           DateTime? @map("sold_out_at") @db.Timestamptz()
  archivedAt          DateTime? @map("archived_at") @db.Timestamptz()
  deletedAt           DateTime? @map("deleted_at") @db.Timestamptz()
  ownerEmail          String?   @map("owner_email")

  items        Item[]
  transactions Transaction[]

  @@map("stores")
}

model Item {
  id                  String   @id @default(uuid())
  storeId             String   @map("store_id")
  productName         String   @map("product_name")
  priceUsdc           Decimal  @map("price_usdc") @db.Decimal(10, 6)
  inventoryTotal      Int      @map("inventory_total")
  inventoryRemaining  Int      @map("inventory_remaining")
  imageUrl            String?  @map("image_url")
  checkoutSessionId   String?  @map("checkout_session_id")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz()

  store        Store         @relation(fields: [storeId], references: [id])
  transactions Transaction[]

  @@map("items")
}

model Transaction {
  id             String   @id @default(uuid())
  storeId        String   @map("store_id")
  itemId         String?  @map("item_id")
  amountUsdc     Decimal  @map("amount_usdc") @db.Decimal(10, 6)
  buyerAddress   String?  @map("buyer_address")
  txHash         String?  @map("tx_hash")
  status         String   @default("PENDING")
  webhookEventId String?  @unique @map("webhook_event_id")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()

  store Store  @relation(fields: [storeId], references: [id])
  item  Item?  @relation(fields: [itemId], references: [id])

  @@map("transactions")
}
